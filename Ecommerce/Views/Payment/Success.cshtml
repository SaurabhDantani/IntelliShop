@{
    ViewData["Title"] = "Order Successful";
    var orderId = Context.Request.Query["orderId"].ToString();
}

<style>
    .success-container {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .success-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05);
        padding: 50px 30px;
        text-align: center;
        max-width: 600px;
        width: 100%;
        border-top: 5px solid #28a745;
    }
    .check-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(40, 167, 69, 0.1);
        color: #28a745;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        margin: 0 auto 20px;
    }
</style>

<div class="success-container">
    <div class="success-card">
        <div class="check-icon">
            <i class="bi bi-check-lg"></i>
        </div>
        <h2 class="fw-bold mb-3">Payment Successful!</h2>
        <p class="text-muted fs-5 mb-4">Thank you for your purchase. Your order has been placed and is being processed.</p>
        
        @if (!string.IsNullOrEmpty(orderId))
        {
            <div class="bg-light p-3 rounded-3 mb-4 d-inline-block">
                <span class="text-muted me-2">Order Tracking ID:</span>
                <span class="fw-bold">#EM-@orderId.PadLeft(6, '0')</span>
            </div>
        }
        
        <div>
            <a href="/" class="btn btn-primary rounded-pill px-5 py-2 fw-semibold shadow-sm">
                Return to Shop
            </a>
        </div>
    </div>
</div>
