@using Ecommerce.Data
@using System.Security.Claims
@inject EcommerceContext DbContext
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ecommerce</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Ecommerce.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        .navbar .nav-link { transition: color 0.2s ease-in-out; }
        .navbar .nav-link:hover { color: #ffc107 !important; }
        .dropdown-menu { animation: fadeIn 0.3s ease-in-out; border-radius: 0.5rem; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow py-3 sticky-top mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold fs-4" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shop text-warning me-2"></i>Ecommerce
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link px-3 active text-white" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link px-3 dropdown-toggle text-light" href="#" id="shopDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Shop
                            </a>
                            <ul class="dropdown-menu shadow border-0" aria-labelledby="shopDropdown">
                                <li><a class="dropdown-item py-2" href="#">All Products</a></li>
                                <li><a class="dropdown-item py-2" href="#">Categories</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger fw-semibold" href="#">Sale & Deals</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 text-light" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                    
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item me-3 d-none d-lg-block">
                            <form class="d-flex position-relative">
                                <input class="form-control rounded-pill pe-5 bg-dark text-white border-secondary focus-ring-warning" type="search" placeholder="Search products..." aria-label="Search" style="width: 250px;">
                                <button class="btn position-absolute end-0 top-0 text-muted" type="submit" style="border:none; background:transparent;">
                                    <i class="bi bi-search"></i>
                                </button>
                            </form>
                        </li>
                        <li class="nav-item me-lg-2 mt-2 mt-lg-0">
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <a class="nav-link position-relative px-2 text-light" asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-cart3 fs-5"></i>
                                    @{
                                        int cartCount = 0;
                                        var uid = User.FindFirstValue(ClaimTypes.NameIdentifier);
                                        if (!string.IsNullOrEmpty(uid))
                                        {
                                            var cart = DbContext.Carts.FirstOrDefault(c => c.UserId == uid);
                                            if (cart != null)
                                            {
                                                cartCount = DbContext.CartItems.Where(ci => ci.CartId == cart.Id).Sum(ci => ci.Quantity);
                                            }
                                        }
                                    }
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark mt-2 ms-n2">
                                        @cartCount
                                        <span class="visually-hidden">items in cart</span>
                                    </span>
                                </a>
                            }
                            else
                            {
                                <a class="nav-link position-relative px-2 text-light" href="#" data-bs-toggle="modal" data-bs-target="#loginModal" onclick="alert('Please log in to view your shopping cart.');">
                                    <i class="bi bi-cart3 fs-5"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning text-dark mt-2 ms-n2">
                                        0
                                        <span class="visually-hidden">items in cart</span>
                                    </span>
                                </a>
                            }
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item ms-lg-3 mt-3 mt-lg-0 w-100 w-lg-auto text-center d-flex align-items-center justify-content-center">
                                <a asp-controller="Admin" asp-action="Index" class="btn btn-outline-warning rounded-pill px-4 fw-semibold shadow-sm me-2"><i class="bi bi-gear-fill me-1"></i> Admin</a>
                                <a asp-controller="User" asp-action="Profile" class="btn btn-outline-light rounded-pill px-4 fw-semibold shadow-sm me-2"><i class="bi bi-person-circle me-1"></i> Profile</a>
                                <a asp-controller="User" asp-action="LogOut" class="btn btn-danger rounded-pill px-4 fw-semibold text-dark shadow-sm">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-lg-3 mt-3 mt-lg-0 w-100 w-lg-auto text-center">
                                <a href="#" class="btn btn-warning rounded-pill px-4 fw-semibold text-dark shadow-sm" data-bs-toggle="modal" data-bs-target="#loginModal">Login</a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm mt-3" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i> <strong>Success!</strong> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm mt-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> <strong>Error!</strong> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center py-4">
            &copy; 2026 - Ecommerce - <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-secondary text-decoration-none hover-warning">Privacy</a>
        </div>
    </footer>

    <!-- Render the login partial modal here -->
    <partial name="_LoginModalPartial" />

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- AI Chat Widget -->
    <button class="btn btn-warning shadow-lg text-dark rounded-circle" id="chatbotToggleBtn" style="position: fixed; bottom: 30px; right: 30px; width: 60px; height: 60px; z-index: 9999; font-size: 1.5rem; transition: transform 0.2s ease;">
        <i class="bi bi-chat-dots-fill"></i>
    </button>

    <div class="card shadow-lg border-0 d-none" id="chatbotWindow" style="position: fixed; bottom: 100px; right: 30px; width: 350px; z-index: 9999; border-radius: 15px; overflow: hidden;">
        <div class="card-header bg-dark text-warning fw-bold d-flex justify-content-between align-items-center py-3">
            <span><i class="bi bi-robot me-2"></i> AI Assistant</span>
            <button type="button" class="btn-close btn-close-white" id="chatbotCloseBtn" style="font-size: 0.8rem;"></button>
        </div>
        <div class="card-body bg-light" id="chatbotMessages" style="height: 300px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px;">
            <div class="p-2 rounded bg-white text-dark shadow-sm align-self-start border" style="max-width: 85%;">
                Hello! I am your AI assistant. Ask me anything about our products!
            </div>
        </div>
        <div class="card-footer bg-white border-top-0 d-flex p-2">
            <input type="text" id="chatbotInput" class="form-control rounded-pill me-2 focus-ring-warning" placeholder="Ask about products..." />
            <button id="chatbotSendBtn" class="btn btn-dark rounded-circle px-2 disabled"><i class="bi bi-send-fill px-1"></i></button>
        </div>
    </div>

    <script>
        $(document).ready(function () {
            const $chatWidget = $('#chatbotWindow');
            const $chatMessages = $('#chatbotMessages');
            const $chatInput = $('#chatbotInput');
            const $chatSendBtn = $('#chatbotSendBtn');

            $('#chatbotToggleBtn').on('click', function () {
                $chatWidget.toggleClass('d-none');
                if (!$chatWidget.hasClass('d-none')) {
                    $chatInput.focus();
                    $(this).css('transform', 'scale(0.8)');
                } else {
                    $(this).css('transform', 'scale(1)');
                }
            });

            $('#chatbotCloseBtn').on('click', function () {
                $chatWidget.addClass('d-none');
                $('#chatbotToggleBtn').css('transform', 'scale(1)');
            });

            $chatInput.on('input', function() {
                if($(this).val().trim().length > 0) {
                    $chatSendBtn.removeClass('disabled');
                } else {
                    $chatSendBtn.addClass('disabled');
                }
            });

            const sendMessage = function () {
                const text = $chatInput.val().trim();
                if (!text) return;

                $chatMessages.append(`
                    <div class="p-2 rounded bg-warning text-dark shadow-sm align-self-end mt-2" style="max-width: 85%;">
                        ${text}
                    </div>
                `);

                $chatInput.val('');
                $chatSendBtn.addClass('disabled');
                $chatMessages.scrollTop($chatMessages[0].scrollHeight);

                const loaderId = 'loader_' + Date.now();
                $chatMessages.append(`
                    <div id="${loaderId}" class="p-2 rounded bg-white text-dark shadow-sm align-self-start mt-2 text-muted border" style="max-width: 85%;">
                        <i class="bi bi-three-dots"></i> Thinking...
                    </div>
                `);
                $chatMessages.scrollTop($chatMessages[0].scrollHeight);

                $.ajax({
                    url: '/api/chat/ask',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ message: text }),
                    success: function (res) {
                        $('#' + loaderId).remove();
                        // Optional simple markdown parsing for bold -> basic HTML handling could be nice, but we'll stick to newlines
                        $chatMessages.append(`
                            <div class="p-2 rounded bg-white text-dark shadow-sm align-self-start mt-2 border" style="max-width: 85%;">
                                ${res.reply.replace(/\n/g, "<br>").replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}
                            </div>
                        `);
                        $chatMessages.scrollTop($chatMessages[0].scrollHeight);
                    },
                    error: function () {
                        $('#' + loaderId).remove();
                        $chatMessages.append(`
                            <div class="p-2 rounded bg-danger text-white shadow-sm align-self-start mt-2" style="max-width: 85%;">
                                Connection error. Try again later.
                            </div>
                        `);
                        $chatMessages.scrollTop($chatMessages[0].scrollHeight);
                    }
                });
            };

            $chatSendBtn.on('click', sendMessage);
            $chatInput.on('keypress', function (e) {
                if (e.which === 13) sendMessage();
            });
        });
    </script>
</body>
</html>
