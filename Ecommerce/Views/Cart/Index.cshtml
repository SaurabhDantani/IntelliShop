@{
    ViewData["Title"] = "Shopping Cart";
    var cartItems = ViewBag.CartItems as List<CartItem> ?? new List<CartItem>();
    
    decimal subtotal = 0;
    foreach(var item in cartItems) 
    {
        subtotal += (decimal)(item.Product!.Price) * (item.Quantity);
    }
    decimal tax = subtotal * 0.08m; // 8% tax
    decimal total = subtotal + tax;
}

<style>
    body {
        background-color: #f8f9fa; /* slightly off-white for depth */
    }
    .cart-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        background: #fff;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .cart-card:hover {
        box-shadow: 0 8px 30px rgba(0,0,0,0.06);
    }
    .product-img-container {
        border-radius: 10px;
        overflow: hidden;
        background: #f1f1f1;
        width: 100%;
        aspect-ratio: 1 / 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .qty-btn {
        width: 32px;
        height: 32px;
        padding: 0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #dee2e6;
        background: #fff;
        color: #495057;
        transition: all 0.2s;
    }
    .qty-btn:hover {
        background: #e9ecef;
        color: #212529;
    }
    .qty-input {
        width: 50px;
        text-align: center;
        border: none;
        background: transparent;
        font-weight: 600;
        font-size: 1rem;
    }
    .qty-input:focus {
        outline: none;
    }
    .btn-remove {
        color: #dc3545;
        background: rgba(220, 53, 69, 0.1);
        border: none;
        border-radius: 8px;
        padding: 8px 12px;
        transition: all 0.2s;
    }
    .btn-remove:hover {
        background: rgba(220, 53, 69, 0.2);
        color: #c82333;
    }
    .summary-card {
        background: linear-gradient(145deg, #ffffff, #fbfbfb);
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05);
        position: sticky;
        top: 100px;
    }
    .checkout-btn {
        background: linear-gradient(90deg, #ff9900, #ffc107);
        border: none;
        color: #000;
        font-weight: 700;
        letter-spacing: 0.5px;
        border-radius: 50px;
        padding: 14px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 153, 0, 0.3);
    }
    .checkout-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(255, 153, 0, 0.4);
    }
    .promo-input {
        border-radius: 50px 0 0 50px;
        border-right: none;
    }
    .promo-btn {
        border-radius: 0 50px 50px 0;
        background: #212529;
        color: #fff;
        border: 1px solid #212529;
    }
    .promo-btn:hover {
        background: #343a40;
        color: #fff;
    }
    .cart-header {
        position: relative;
        padding-bottom: 10px;
    }
    .cart-header::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        width: 60px;
        height: 4px;
        background: #ffc107;
        border-radius: 2px;
    }
</style>

<div class="row mt-4 mb-5">
    <div class="col-lg-8 mb-4 mb-lg-0">
        <div class="d-flex justify-content-between align-items-end mb-4 cart-header">
            <h2 class="fw-bold mb-0 text-dark">Shopping Cart</h2>
            <span class="text-muted fw-semibold">@cartItems.Count items</span>
        </div>

        @if (!cartItems.Any())
        {
            <div class="alert alert-light text-center py-5 shadow-sm rounded-4">
                <i class="bi bi-cart-x text-muted" style="font-size: 3rem;"></i>
                <h4 class="mt-3 fw-bold text-dark">Your cart is empty</h4>
                <p class="text-muted">Looks like you haven't added anything to your cart yet.</p>
                <a href="/" class="btn btn-warning rounded-pill px-4 mt-3 fw-semibold">Start Shopping</a>
            </div>
        }
        else
        {
            @foreach (var i in cartItems)
            {            
                <div class="card cart-card mb-4">
                    <div class="card-body p-4">
                        <div class="row align-items-center">
                            <div class="col-md-2 col-4 mb-3 mb-md-0">
                                <div class="product-img-container shadow-sm">
                                    <!-- Fallback image logic if real DB URLs aren't populated -->
                                    <img src="~/images/product_headphones.png" alt="@i.Product.Name" class="product-img" />
                                </div>
                            </div>
                            <div class="col-md-4 col-8 mb-3 mb-md-0">
                                <h5 class="fw-bold text-dark mb-1">@i.Product.Name</h5>
                                <p class="text-muted mb-0 small">Category: @(i.Product.Category?.Name ?? "General")</p>
                            </div>
                            <div class="col-md-3 col-6 d-flex align-items-center justify-content-md-center">
                                <div class="d-flex align-items-center bg-light rounded-pill p-1 shadow-sm">
                                    <form method="post" asp-controller="Cart" asp-action="UpdateQuantity" class="m-0">
                                        <input type="hidden" name="cartItemId" value="@i.Id" />
                                        <input type="hidden" name="change" value="-1" />
                                        <button class="qty-btn" type="submit"><i class="bi bi-dash"></i></button>
                                    </form>
                                    <input type="text" class="qty-input" value="@i.Quantity" readonly>
                                    <form method="post" asp-controller="Cart" asp-action="UpdateQuantity" class="m-0">
                                        <input type="hidden" name="cartItemId" value="@i.Id" />
                                        <input type="hidden" name="change" value="1" />
                                        <button class="qty-btn" type="submit"><i class="bi bi-plus"></i></button>
                                    </form>
                                </div>
                            </div>
                            <div class="col-md-2 col-3 text-end text-md-center">
                                <span class="fw-bold fs-5 text-dark">$@i.Product.Price</span>
                            </div>
                            <div class="col-md-1 col-3 text-end">
                                <form method="post" asp-controller="Cart" asp-action="Remove" class="m-0">
                                    <input type="hidden" name="cartItemId" value="@i.Id" />
                                    <button class="btn-remove shadow-sm" title="Remove Item" type="submit"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
      
        <div class="mt-4">
            <a href="/" class="text-decoration-none text-dark fw-semibold d-inline-flex align-items-center hover-warning" style="transition: color 0.2s;">
                <i class="bi bi-arrow-left me-2"></i> Continue Shopping
            </a>
        </div>
    </div>

    <!-- Order Summary -->
    <div class="col-lg-4">
        <div class="summary-card p-4">
            <h4 class="fw-bold mb-4">Order Summary</h4>
            
            <div class="mb-4">
                <div class="input-group shadow-sm" style="border-radius: 50px;">
                    <input type="text" class="form-control promo-input focus-ring-warning" placeholder="Promo code">
                    <button class="btn promo-btn px-4" type="button">Apply</button>
                </div>
            </div>

            <div class="d-flex justify-content-between mb-3 text-muted">
                <span>Subtotal</span>
                <span class="fw-medium text-dark">$@subtotal.ToString("0.00")</span>
            </div>
            <div class="d-flex justify-content-between mb-3 text-muted">
                <span>Shipping</span>
                <span class="fw-medium text-success">Free</span>
            </div>
            <div class="d-flex justify-content-between mb-3 text-muted">
                <span>Estimated Tax (8%)</span>
                <span class="fw-medium text-dark">$@tax.ToString("0.00")</span>
            </div>
            
            <hr class="my-4 border-secondary opacity-25">
            
            <div class="d-flex justify-content-between mb-4">
                <span class="fw-bold fs-5 text-dark">Total</span>
                <span class="fw-bold fs-4 text-dark">$@total.ToString("0.00")</span>
            </div>
            
            <a href="/Payment/Index" class="btn checkout-btn w-100 mb-3 text-uppercase text-center text-decoration-none d-block" @(cartItems.Any() ? "" : "style=pointer-events:none;opacity:0.5;")>
                Proceed to Checkout <i class="bi bi-arrow-right ms-2"></i>
            </a>
            
            <div class="text-center mt-3">
                <p class="small text-muted mb-2">We accept</p>
                <div class="d-flex justify-content-center gap-3 text-muted fs-4">
                    <i class="bi bi-credit-card-fill" title="Credit Card"></i>
                    <i class="bi bi-stripe" title="Stripe"></i>
                    <i class="bi bi-paypal" title="PayPal"></i>
                    <i class="bi bi-apple" title="Apple Pay"></i>
                </div>
            </div>
        </div>
    </div>
</div>
