@model IEnumerable<Ecommerce.Models.Orders>
@{
    ViewData["Title"] = "My Profile";
    var user = ViewBag.User as Ecommerce.Models.AspNetUser;
}

<style>
    body {
        background-color: #f4f6f9;
    }
    .profile-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        background: #fff;
    }
    .order-card {
        border-left: 4px solid #ffc107;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border-radius: 10px;
    }
    .order-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
    }
    .status-badge {
        padding: 5px 12px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.85rem;
    }
</style>

<div class="row mt-4 mb-5">
    <div class="col-lg-4 mb-4">
        <div class="card profile-card p-4 text-center h-100">
            <div class="d-flex justify-content-center mb-3">
                <div class="bg-warning text-dark d-flex align-items-center justify-content-center rounded-circle fw-bold fs-1" style="width: 100px; height: 100px;">
                    @(!string.IsNullOrEmpty(user?.FirstName) ? user.FirstName.Substring(0, 1).ToUpper() : "U")
                </div>
            </div>
            <h4 class="fw-bold mb-1">@(user?.FirstName) @(user?.LastName)</h4>
            <p class="text-muted mb-4">@user?.Email</p>
            
            <hr class="text-muted opacity-25">
            
            <div class="text-start mt-3">
                <p class="mb-2"><i class="bi bi-clock-history me-2 text-warning"></i> Member since @DateTime.Now.Year</p>
                <p class="mb-0"><i class="bi bi-bag-check me-2 text-success"></i> @Model.Count() lifetime orders</p>
            </div>
        </div>
    </div>
    
    <div class="col-lg-8 mb-4">
        <h3 class="fw-bold text-dark mb-4"><i class="bi bi-receipt me-2 text-warning"></i> Order History</h3>
        
        @if (!Model.Any())
        {
            <div class="alert alert-light text-center py-5 shadow-sm rounded-4">
                <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
                <h5 class="mt-3 fw-bold text-dark">No orders yet</h5>
                <p class="text-muted">You haven't placed any orders yet. Start shopping to see them here.</p>
                <a href="/" class="btn btn-warning rounded-pill px-4 mt-2 fw-semibold">Browse Products</a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 g-4">
                @foreach (var order in Model)
                {
                    <div class="col">
                        <div class="card order-card profile-card border-0">
                            <div class="card-body p-4">
                                <div class="row align-items-center">
                                    <div class="col-md-3 mb-3 mb-md-0">
                                        <p class="text-muted small mb-1">Order #</p>
                                        <h6 class="fw-bold text-dark mb-0">EM-@order.Id.ToString().PadLeft(6, '0')</h6>
                                    </div>
                                    <div class="col-md-3 mb-3 mb-md-0">
                                        <p class="text-muted small mb-1">Date</p>
                                        <p class="fw-semibold text-dark mb-0">
                                            @(order.Payment?.PaymentDate.ToString("MMM dd, yyyy") ?? "Unknown")
                                        </p>
                                    </div>
                                    <div class="col-md-3 mb-3 mb-md-0">
                                        <p class="text-muted small mb-1">Total</p>
                                        <h6 class="fw-bold text-success mb-0">$@order.TotalAmount.ToString("0.00")</h6>
                                    </div>
                                    <div class="col-md-3 text-md-end">
                                        @if (order.Payment != null)
                                        {
                                            <span class="status-badge bg-success bg-opacity-10 text-success border border-success border-opacity-25">
                                                <i class="bi bi-check-circle-fill me-1"></i> Paid (@order.Payment.PaymentMethod)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25">
                                                Pending
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
